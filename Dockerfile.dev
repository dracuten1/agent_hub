FROM golang:1.21-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o agenthub ./cmd/server

FROM golang:1.21-alpine
WORKDIR /app
COPY --from=builder /app/agenthub .
COPY --from=builder /app/web/dist ./web/dist

EXPOSE 8081
CMD ["./agenthub"]
