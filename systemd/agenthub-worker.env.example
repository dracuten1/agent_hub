# AgentHub Worker Environment Configuration
# Copy this to /etc/default/agenthub-worker or set variables inline in the systemd unit.
#
# Lines starting with # are comments.
# Lines starting with export set environment variables.

# =============================================================================
# REQUIRED: OpenCode API Key
# =============================================================================
# Get your API key from https://opencode.ai
export DAODUC_API_KEY=sk-your-api-key-here

# =============================================================================
# AgentHub Connection
# =============================================================================
# URL of the AgentHub API server
export AGENTHUB_URL=http://localhost:8081

# API token (set in AgentHub dashboard if auth is enabled)
export AGENTHUB_TOKEN=

# =============================================================================
# Worker Settings
# =============================================================================
# Poll interval in seconds (default: 10)
# export AGENTHUB_POLL_INTERVAL=10

# Log level: debug, info, warn, error (default: info)
# export AGENTHUB_LOG_LEVEL=info
